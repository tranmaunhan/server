CLOUDFLARE_TUNNEL_TOKEN=
DEPLOY_TOKEN=
# Optional. Leave blank to reuse DEPLOY_TOKEN for admin UI/API.
DEPLOY_ADMIN_TOKEN=
DEPLOY_MANAGER_IMAGE=your-dockerhub-user/deploy-manager:latest
SPRING_API_IMAGE=your-dockerhub-user/sample-spring-api:latest
REACT_WEB_IMAGE=your-dockerhub-user/sample-react-web:latest
# Bind deploy-manager UI/API only on localhost by default.
DEPLOY_MANAGER_PORT_BIND=127.0.0.1:18080
# Path on the Docker host that contains docker-compose.yml, .env, nginx/, deploy-manager/.
DEPLOY_HOST_ROOT=.
COMPOSE_PROJECT_DIR=/workspace
COMPOSE_FILE_PATH=/workspace/docker-compose.yml
COMPOSE_ENV_FILE=/workspace/.env
POSTGRES_DB=sampledb
POSTGRES_USER=sample
POSTGRES_PASSWORD=samplepass
